# -----------------------------------------------------------------------------
# LoveSaving AI Insights backend local/cloud configuration template
#
# Copy this file to `.env.local` for local development.
# Do NOT commit real secrets.
#
# Recommended local/full-stack defaults for this project:
# - auth: firebase
# - llm: openai
# - storage: firestore
# - tasks: direct
#
# `local` / `stub` / `memory` modes still exist for backend-only tests, but they
# are not the preferred app-level local development flow anymore.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Runtime role
# -----------------------------------------------------------------------------
# Which deployment role this process is playing.
# Allowed values:
# - api   : public chat API service
# - task  : internal task worker service
APP_ROLE=api

# -----------------------------------------------------------------------------
# Auth mode
# -----------------------------------------------------------------------------
# How requests are authenticated.
# Allowed values:
# - firebase : requires Authorization: Bearer <Firebase ID token>
# - local    : backend-only debug mode; bypasses Firebase auth
AI_AUTH_MODE=firebase

# Used only when AI_AUTH_MODE=local.
# Any non-empty string is acceptable.
AI_LOCAL_DEBUG_USER_ID=local-dev-user

# -----------------------------------------------------------------------------
# LLM mode
# -----------------------------------------------------------------------------
# Which upstream LLM behavior to use.
# Allowed values:
# - openai : real OpenAI upstream streaming
# - stub   : backend-only fake streaming mode for tests
AI_LLM_MODE=openai

# OpenAI API key.
# Required when AI_LLM_MODE=openai.
# In Cloud Run, inject this from Secret Manager instead of hardcoding it.
OPENAI_API_KEY=replace-me

# Primary provider router choice.
# Currently supported values in this repo:
# - openai
PRIMARY_MODEL_PROVIDER=openai

# Main text model for standard chat requests.
# Example values:
# - gpt-5.4-nano
# - gpt-5.4-mini
# - gpt-5.4
PRIMARY_TEXT_MODEL=gpt-5.4-nano

# Main multimodal model for requests with image/file inputs.
# Leave blank if Phase 1 is text-only for now.
# Example values:
# - gpt-5.4-nano
# - gpt-5.4-mini
PRIMARY_MULTIMODAL_MODEL=

# Optional secondary provider/model for future fallback logic.
# Safe to leave blank in Phase 1.
# Example provider values:
# - openai
SECONDARY_MODEL_PROVIDER=
SECONDARY_TEXT_MODEL=

# -----------------------------------------------------------------------------
# Storage mode
# -----------------------------------------------------------------------------
# Where chat/memory/title state is stored.
# Allowed values:
# - firestore : real Firestore-backed storage
# - memory    : backend-only in-process store for tests
AI_STORAGE_MODE=firestore

# Firebase / GCP project id.
# Required when:
# - AI_AUTH_MODE=firebase
# - AI_STORAGE_MODE=firestore
# - AI_TASK_MODE=cloud_tasks
# Example:
# FIREBASE_PROJECT_ID=lovesaving-72814
FIREBASE_PROJECT_ID=your-firebase-project-id

# -----------------------------------------------------------------------------
# Task mode
# -----------------------------------------------------------------------------
# How cold-path work is dispatched.
# Allowed values:
# - direct      : execute title/memory work in-process
# - cloud_tasks : enqueue to Google Cloud Tasks and call task-service
AI_TASK_MODE=direct

# Cloud Tasks queue region.
# Should match your Cloud Run region in Phase 1.
# Example:
# - us-central1
CLOUD_TASKS_LOCATION=us-central1

# Cloud Tasks queue name.
# Example:
# - ai-insights-default
CLOUD_TASKS_QUEUE_ID=ai-insights-default

# Base URL of the deployed task-service.
# Required when AI_TASK_MODE=cloud_tasks.
# Example local split run:
# TASK_SERVICE_URL=http://localhost:8081
# Example Cloud Run:
# TASK_SERVICE_URL=https://task-service-xxxxx-uc.a.run.app
TASK_SERVICE_URL=https://task-service-placeholder.run.app

# Service account email used by Cloud Tasks to invoke task-service.
# Required when AI_TASK_MODE=cloud_tasks.
# Example:
# CLOUD_TASKS_INVOKER_SERVICE_ACCOUNT_EMAIL=cloud-tasks-invoker-sa@your-project-id.iam.gserviceaccount.com
CLOUD_TASKS_INVOKER_SERVICE_ACCOUNT_EMAIL=

# Shared secret used to protect /internal/tasks/* endpoints from arbitrary callers.
# Required when:
# - AI_TASK_MODE=cloud_tasks
# - AI_AUTH_MODE=firebase
# Example:
# AI_INTERNAL_TASK_SHARED_SECRET=replace-with-a-long-random-string
AI_INTERNAL_TASK_SHARED_SECRET=

# -----------------------------------------------------------------------------
# Prompt/context tuning
# -----------------------------------------------------------------------------
# Default number of recent days of relationship context to pull into chat.
# Must be a positive integer.
# Example values:
# - 7
# - 14
RECENT_CONTEXT_DAYS_DEFAULT=7

# Minimum time between long-term memory refreshes.
# Must be a positive integer number of hours.
# Example values:
# - 24
# - 48
# - 72
MEMORY_REFRESH_MIN_INTERVAL_HOURS=48

# Minimum number of new events/messages needed before refreshing memory.
# Must be a positive integer.
# Example values:
# - 5
# - 10
# - 20
MEMORY_REFRESH_MIN_NEW_EVENTS=10
